{
    "name": "RefundAgent",
    "description": "Agent that exclusively processes refunds for customers.",
    "url": "http://localhost:8030/",
    "version": "1.0.0",
    "preferredTransport": "JSONRPC",
    "protocolVersion": "0.3.0",
    "capabilities": {
        "streaming": true,
        "pushNotifications": true,
        "stateTransitionHistory": false
    },
    "defaultInputModes": [
        "text",
        "text/plain"
    ],
    "defaultOutputModes": [
        "text",
        "text/plain"
    ],
    "skills": [
        {
            "id": "refund_processing",
            "name": "Refund Processing",
            "description": "Handle customer refund requests for tracks and purchases.",
            "tags": [
                "refund",
                "billing",
                "customer service"
            ],
            "examples": [
                "I want a refund for the track 'Highway to Hell'. My customer ID is 1."
            ]
        }
    ]
}

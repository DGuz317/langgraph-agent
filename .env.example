# --- LLM CHAT SETTINGS ---
LLM_MODEL=gpt-oss # default is gpt-oss or gemma4
MODEL_PROVIDER=ollama
OLLAMA_API_URL=http://localhost:11434


# --- EMBEDDING SETTINGS (For server.py database search) ---
EMBED_MODEL=nomic-embed-text

# --- DATABASE SETTINGS ---
SQLLITE_DB=sqlite:////home/nvdung1/Desktop/MultiAgentSystem/langgraph-agent/src/agent_app/database/chinook.db

# --- GOOGLE GEMINI SETTINGS ---
# Options: gemini-2.0-flash-exp (50 req/day), 
#          gemini-1.5-flash (1500 req/day), 
#          gemini-1.5-pro, gemini-2.5-flash-lite
# LLM_MODEL=gemini-2.0-flash
# GOOGLE_API_KEY=""
# GOOGLE_GENAI_USE_VERTEXAI=FALSE


# --- Optional for LangSmith tracing and tracking ---
LANGSMITH_API_KEY="lsv2"
LANGSMITH_ENDPOINT="https://api.smith.langchain.com" #defaults to https://api.smith.langchain.com if using cloud
LANGSMITH_TRACING="true"
LANGSMITH_PROJECT="multi-agent-system"


# --- MCP SERVER SETTINGS ---
MCP_SERVER_NAME="data_tools"
MCP_SERVER_URL=http://localhost:10000
MCP_TRANSPORT=streamable-http # Or stdio
MCP_PORT=10000
MCP_HOST=localhost

# --- AGENT SETTINGS ---
